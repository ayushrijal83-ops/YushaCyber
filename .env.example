# =============================================================================
# YushaCyber environment (YC-025.0)
# =============================================================================
# Copy this file to `.env`, fill in real values, and NEVER commit `.env`.
# Every setting has a safe default; every commented line is optional.
# =============================================================================

# ---- REQUIRED --------------------------------------------------------------
# Session/CSRF signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# ---- Environment selector --------------------------------------------------
# `development` (default) enables debug; `production` turns it off, hardens
# cookies, and turns on HSTS.
APP_ENV=development

# ---- Database --------------------------------------------------------------
# Default is a SQLite file inside ./instance/. Override for Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Cookies / TLS (enable behind HTTPS) -----------------------------------
# SESSION_COOKIE_SECURE=true

# ---- Logging ---------------------------------------------------------------
# LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
# APP_VERSION=v1.0.0   # returned by /health for release identification

# ---- Debug (development only) ----------------------------------------------
# FLASK_DEBUG=false
